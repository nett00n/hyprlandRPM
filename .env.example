# Packager identity for RPM spec files
PACKAGER="Your Name <your.email@example.com>"
PACKAGER_NAME="Your Name"
PACKAGER_EMAIL="your.email@example.com"

# COPR repository (e.g., "username/hyprland")
COPR_REPO=""

# Default Fedora version for builds (42, 43, 44, or rawhide)
FEDORA_VERSION="43"

# Package to build (leave empty to build all)
PACKAGE=""

# Build control flags
SKIP_PACKAGES=""
PROCEED_BUILD=""
FORCE_MOCK=""
