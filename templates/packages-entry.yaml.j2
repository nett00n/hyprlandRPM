
{{ key }}:
  version: "{{ version }}"
  release: "%autorelease"
  license: {{ license_id }}
  summary: {{ summary }}
  description: |
    FIXME
  url: {{ url }}
  depends_on:
{% if depends_on %}
{% for dep in depends_on %}
    - {{ dep }}
{% endfor %}
{% else %}
    []
    # - hyprutils
{% endif %}
  build_requires:
{% if build_requires %}
{% for dep in build_requires %}
    - {{ dep }}
{% endfor %}
{% else %}
    []
{% endif %}
  requires:
    []
  files:
    - "%license LICENSE"
    - "%doc README.md"
{% if build_system == "golang" %}
    - "%{_bindir}/{{ key }}"
{% else %}
    # FIXME: add installed files
{% endif %}
  # devel: generates a -devel subpackage for headers, pkgconfig files, cmake modules, etc.
  devel:
    files:
      []
      # - "%{_includedir}/{{ key }}/"
      # - "%{_libdir}/pkgconfig/{{ key }}.pc"
  source:
    # source_name: top-level directory inside the tarball when it differs from the package name
{% if source_name %}
    name: "{{ source_name }}"
{% else %}
    # name: "{{ key }}"
{% endif %}
{% if commit %}
    # commit: used for git snapshot releases when no version tag is available
    commit:
      full: {{ commit.full }}
      date: "{{ commit.date }}"
{% endif %}
    archives:
      - {{ source_url }}
    bundled_deps:
      []
  build:
    # system: cmake | meson | autotools | make | configure | python | golang
    system: {{ build_system }}
{% if go_subdir %}
    # go_subdir: subdirectory containing go.mod when the Go module is not at the tarball root
    go_subdir: {{ go_subdir }}
{% else %}
    # go_subdir: subdirectory containing go.mod when the Go module is not at the tarball root
    # go_subdir: cli
{% endif %}
    # configure_flags: extra flags passed to ./configure (only used with system: configure)
    # configure_flags: []
    # prep: extra shell commands injected into %prep after %autosetup
    prep:
      []
    # commands: override the default build commands derived from system
{% if build_commands %}
    commands:
{% for cmd in build_commands %}
      - {{ cmd }}
{% endfor %}
{% else %}
    commands:
      []
{% endif %}
    # install: override the default install commands derived from system
{% if install_commands %}
    install:
{% for cmd in install_commands %}
      - {{ cmd }}
{% endfor %}
{% else %}
    install:
      []
{% endif %}
    # no_lto: disable LTO (Link-Time Optimization) for packages that don't support it
    no_lto: false
  rpm:
    # buildarch: set to "noarch" for architecture-independent packages (scripts, headers-only, etc.)
{% if buildarch %}
    buildarch: "{{ buildarch }}"
{% else %}
    # buildarch: noarch
{% endif %}
    # no_debug_package: suppress the automatic -debuginfo subpackage (useful for header-only or noarch)
    no_debug_package: {{ 'true' if no_debug_package else 'false' }}
