{% macro badge(label, state, url=None) -%}
{%- set state_colors = {'success': 'brightgreen', 'failed': 'red', 'skipped': 'lightgrey'} -%}
{%- set s = state or 'unknown' -%}
{%- set color = state_colors.get(s, 'orange') -%}
{%- set img_url = 'https://img.shields.io/badge/' ~ label ~ '-' ~ s ~ '-' ~ color ~ (('?style=' ~ badge_style) if badge_style else '') -%}
{%- set img = '![' ~ label ~ '](' ~ img_url ~ ')' -%}
{%- if url %}[{{ img }}]({{ url }}){% else %}{{ img }}{% endif -%}
{%- endmacro %}
{% macro ver_badge(pkg) -%}
{% if pkg.badge -%}
![{{ pkg.version }}](https://img.shields.io/badge/{{ pkg.version | replace('-', '--') }}-{{ pkg.badge.color }}?logo={{ pkg.badge.logo }}&logoColor={{ pkg.badge.logo_color }}&style={{ badge_style }})
{%- else -%}
![{{ pkg.version }}](https://img.shields.io/badge/{{ pkg.version | replace('-', '--') }}-D6D6D6?logo=gitlfs&logoColor=black&style={{ badge_style }})
{%- endif %}
{%- endmacro %}
